      "source": [
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from io import StringIO\n",
        "\n",
        "data = \"\"\"timestamp,temperature\n",
        "2026-04-10 08:00,25\n",
        "2026-04-10 12:00,32\n",
        "2026-04-10 18:00,28\n",
        "2026-04-11 08:00,26\n",
        "2026-04-11 12:00,33\n",
        "2026-04-11 18:00,29\n",
        "\"\"\"\n",
        "df = pd.read_csv(StringIO(data))\n",
        "\n",
        "\n",
        "df['date'] = pd.to_datetime(df['timestamp']).dt.date\n",
        "\n",
        "daily = df.groupby('date')['temperature'].agg(['max','min'])\n",
        "\n",
        "base_temp = 10\n",
        "daily['GDD'] = ((daily['max'] + daily['min']) / 2) - base_temp\n",
        "\n",
        "daily['Cumulative_GDD'] = daily['GDD'].cumsum()\n",
        "\n",
        "print(\"=== DAILY DATA ===\")\n",
        "print(daily)\n",
        "\n",
        "plt.figure()\n",
        "daily['GDD'].plot()\n",
        "plt.title(\"GDD per Day\")\n",
        "plt.xlabel(\"Date\")\n",
        "plt.ylabel(\"GDD\")\n",
        "plt.show()\n",
        "\n",
        "plt.figure()\n",
        "daily['Cumulative_GDD'].plot()\n",
        "plt.title(\"Cumulative GDD\")\n",
        "plt.xlabel(\"Date\")\n",
        "plt.ylabel(\"Total GDD\")\n",
        "plt.show()"
