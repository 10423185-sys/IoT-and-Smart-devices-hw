        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "data = {\n",
        "    \"sensor\": [650, 600, 550],\n",
        "    \"wet\":    [212, 220, 230],\n",
        "    \"dry\":    [197, 200, 205]\n",
        "}\n",
        "\n",
        "df = pd.DataFrame(data)\n",
        "\n",
        "df[\"moisture_%\"] = (df[\"wet\"] - df[\"dry\"]) / df[\"dry\"] * 100\n",
        "\n",
        "print(\"=== DATA ===\")\n",
        "print(df)\n",
        "\n",
        "plt.figure()\n",
        "plt.scatter(df[\"sensor\"], df[\"moisture_%\"])\n",
        "\n",
        "a, b = np.polyfit(df[\"sensor\"], df[\"moisture_%\"], 1)\n",
        "\n",
        "x = np.linspace(min(df[\"sensor\"]), max(df[\"sensor\"]), 100)\n",
        "y = a * x + b\n",
        "\n",
        "plt.plot(x, y)\n",
        "\n",
        "plt.xlabel(\"Sensor Reading\")\n",
        "plt.ylabel(\"Soil Moisture (%)\")\n",
        "plt.title(\"Calibration Curve\")\n",
        "plt.show()\n",
        "sensor_value = 580  # ví dụ\n",
        "predicted = a * sensor_value + b\n",
        "\n",
        "print(\"\\nSensor =\", sensor_value)\n",
        "print(\"Estimated Soil Moisture =\", round(predicted, 2), \"%\")"
      ],
